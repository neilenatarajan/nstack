#!/usr/bin/env bash
# nstack setup — build browser binary + register skills with Claude Code / Codex
set -e
umask 077  # Restrict new files to owner-only (0o600 files, 0o700 dirs)

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install with checksum verification:" >&2
  echo '  BUN_VERSION="1.3.10"' >&2
  echo '  tmpfile=$(mktemp)' >&2
  echo '  curl -fsSL "https://bun.sh/install" -o "$tmpfile"' >&2
  echo '  echo "Verify checksum before running: shasum -a 256 $tmpfile"' >&2
  echo '  BUN_VERSION="$BUN_VERSION" bash "$tmpfile" && rm "$tmpfile"' >&2
  exit 1
fi

INSTALL_NSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_NSTACK_DIR="$(cd "$(dirname "$0")" && pwd -P)"
INSTALL_SKILLS_DIR="$(dirname "$INSTALL_NSTACK_DIR")"
BROWSE_BIN="$SOURCE_NSTACK_DIR/browse/dist/browse"
CODEX_SKILLS="$HOME/.codex/skills"
CODEX_NSTACK="$CODEX_SKILLS/nstack"
FACTORY_SKILLS="$HOME/.factory/skills"
FACTORY_NSTACK="$FACTORY_SKILLS/nstack"

IS_WINDOWS=0
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT) IS_WINDOWS=1 ;;
esac

# ─── Quiet mode helper ────────────────────────────────────────
QUIET=0
log() { [ "$QUIET" -eq 0 ] && echo "$@" || true; }

# ─── Parse flags ──────────────────────────────────────────────
HOST="claude"
LOCAL_INSTALL=0
SKILL_PREFIX=1
TEAM_MODE=0
NO_TEAM_MODE=0
while [ $# -gt 0 ]; do
  case "$1" in
    --host) [ -z "$2" ] && echo "Missing value for --host (expected claude, codex, kiro, or auto)" >&2 && exit 1; HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    --local) LOCAL_INSTALL=1; shift ;;
    --prefix)    shift ;;  # Accepted for backwards compat, always prefixed
    --no-prefix) echo "Warning: --no-prefix is deprecated. Skills are always prefixed with nstack-." >&2; shift ;;
    --team)    TEAM_MODE=1; shift ;;
    --no-team) NO_TEAM_MODE=1; shift ;;
    -q|--quiet) QUIET=1; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  claude|codex|kiro|factory|auto) ;;
  openclaw)
    echo ""
    echo "OpenClaw integration uses a different model — OpenClaw spawns Claude Code"
    echo "sessions natively via ACP. nstack provides methodology artifacts, not a"
    echo "full skill installation."
    echo ""
    echo "To integrate nstack with OpenClaw:"
    echo "  1. Tell your OpenClaw agent: 'install nstack for openclaw'"
    echo "  2. Or generate artifacts: bun run gen:skill-docs --host openclaw"
    echo "  3. See docs/OPENCLAW.md for the full architecture"
    echo ""
    exit 0 ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, kiro, factory, openclaw, or auto)" >&2; exit 1 ;;
esac

# Skills are always prefixed with nstack-
NSTACK_CONFIG="$SOURCE_NSTACK_DIR/bin/nstack-config"

# --local: install to .claude/skills/ in the current working directory (deprecated)
if [ "$LOCAL_INSTALL" -eq 1 ]; then
  echo "Warning: --local is deprecated. Use global install + --team instead." >&2
  echo "  See: https://github.com/garrytan/nstack#team-mode" >&2
  if [ "$HOST" = "codex" ]; then
    echo "Error: --local is only supported for Claude Code (not Codex)." >&2
    exit 1
  fi
  INSTALL_SKILLS_DIR="$(pwd)/.claude/skills"
  mkdir -p "$INSTALL_SKILLS_DIR"
  HOST="claude"
  INSTALL_CODEX=0
fi

# For auto: detect which agents are installed
INSTALL_CLAUDE=0
INSTALL_CODEX=0
INSTALL_KIRO=0
INSTALL_FACTORY=0
if [ "$HOST" = "auto" ]; then
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex >/dev/null 2>&1 && INSTALL_CODEX=1
  command -v kiro-cli >/dev/null 2>&1 && INSTALL_KIRO=1
  command -v droid >/dev/null 2>&1 && INSTALL_FACTORY=1
  # If none found, default to claude
  if [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ] && [ "$INSTALL_KIRO" -eq 0 ] && [ "$INSTALL_FACTORY" -eq 0 ]; then
    INSTALL_CLAUDE=1
  fi
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
elif [ "$HOST" = "kiro" ]; then
  INSTALL_KIRO=1
elif [ "$HOST" = "factory" ]; then
  INSTALL_FACTORY=1
fi

migrate_direct_codex_install() {
  local nstack_dir="$1"
  local codex_nstack="$2"
  local migrated_dir="$HOME/.nstack/repos/nstack"

  [ "$nstack_dir" = "$codex_nstack" ] || return 0
  [ -L "$nstack_dir" ] && return 0

  mkdir -p "$(dirname "$migrated_dir")"
  if [ -e "$migrated_dir" ] && [ "$migrated_dir" != "$nstack_dir" ]; then
    echo "nstack setup failed: direct Codex install detected at $nstack_dir" >&2
    echo "A migrated repo already exists at $migrated_dir; move one of them aside and rerun setup." >&2
    exit 1
  fi

  log "Migrating direct Codex install to $migrated_dir to avoid duplicate skill discovery..."
  mv "$nstack_dir" "$migrated_dir"
  SOURCE_NSTACK_DIR="$migrated_dir"
  INSTALL_NSTACK_DIR="$migrated_dir"
  INSTALL_SKILLS_DIR="$(dirname "$INSTALL_NSTACK_DIR")"
  BROWSE_BIN="$SOURCE_NSTACK_DIR/browse/dist/browse"
}

if [ "$INSTALL_CODEX" -eq 1 ]; then
  migrate_direct_codex_install "$SOURCE_NSTACK_DIR" "$CODEX_NSTACK"
fi

ensure_playwright_browser() {
  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Bun can't launch Chromium due to broken pipe handling
    # (oven-sh/bun#4253). Use Node.js to verify Chromium works instead.
    (
      cd "$SOURCE_NSTACK_DIR"
      node -e "const { chromium } = require('playwright'); (async () => { const b = await chromium.launch(); await b.close(); })()" 2>/dev/null
    )
  else
    (
      cd "$SOURCE_NSTACK_DIR"
      bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
    ) >/dev/null 2>&1
  fi
}

# 1. Build browse binary if needed (smart rebuild: stale sources, package.json, lock)
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$SOURCE_NSTACK_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$SOURCE_NSTACK_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$SOURCE_NSTACK_DIR/bun.lock" ] && [ "$SOURCE_NSTACK_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  log "Building browse binary..."
  (
    cd "$SOURCE_NSTACK_DIR"
    bun install
    bun run build
  )
  # Safety net: write .version if build script didn't (e.g., git not available during build)
  if [ ! -f "$SOURCE_NSTACK_DIR/browse/dist/.version" ]; then
    git -C "$SOURCE_NSTACK_DIR" rev-parse HEAD > "$SOURCE_NSTACK_DIR/browse/dist/.version" 2>/dev/null || true
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "nstack setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 1b. Generate .agents/ Codex skill docs — always regenerate to prevent stale descriptions.
# .agents/ is no longer committed — generated at setup time from .tmpl templates.
# bun run build already does this, but we need it when NEEDS_BUILD=0 (binary is fresh).
# Always regenerate: generation is fast (<2s) and mtime-based staleness checks are fragile
# (miss stale files when timestamps match after clone/checkout/upgrade).
AGENTS_DIR="$SOURCE_NSTACK_DIR/.agents/skills"
NEEDS_AGENTS_GEN=1

if [ "$NEEDS_AGENTS_GEN" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  log "Generating .agents/ skill docs..."
  (
    cd "$SOURCE_NSTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host codex
  )
fi

# 1c. Generate .factory/ Factory Droid skill docs
if [ "$INSTALL_FACTORY" -eq 1 ] && [ "$NEEDS_BUILD" -eq 0 ]; then
  log "Generating .factory/ skill docs..."
  (
    cd "$SOURCE_NSTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host factory
  )
fi

# 2. Ensure Playwright's Chromium is available
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$SOURCE_NSTACK_DIR"
    bunx playwright install chromium
  )

  if [ "$IS_WINDOWS" -eq 1 ]; then
    # On Windows, Node.js launches Chromium (not Bun — see oven-sh/bun#4253).
    # Ensure playwright is importable by Node from the nstack directory.
    if ! command -v node >/dev/null 2>&1; then
      echo "nstack setup failed: Node.js is required on Windows (Bun cannot launch Chromium due to a pipe bug)" >&2
      echo "  Install Node.js: https://nodejs.org/" >&2
      exit 1
    fi
    echo "Windows detected — verifying Node.js can load Playwright..."
    (
      cd "$SOURCE_NSTACK_DIR"
      # Bun's node_modules already has playwright; verify Node can require it
      node -e "require('playwright')" 2>/dev/null || npm install --no-save playwright
    )
  fi
fi

if ! ensure_playwright_browser; then
  if [ "$IS_WINDOWS" -eq 1 ]; then
    echo "nstack setup failed: Playwright Chromium could not be launched via Node.js" >&2
    echo "  This is a known issue with Bun on Windows (oven-sh/bun#4253)." >&2
    echo "  Ensure Node.js is installed and 'node -e \"require('playwright')\"' works." >&2
  else
    echo "nstack setup failed: Playwright Chromium could not be launched" >&2
  fi
  exit 1
fi

# 3. Ensure ~/.nstack global state directory exists
mkdir -p "$HOME/.nstack/projects"

# 3a. Configure merge driver for fork-customized files (.gitattributes merge=ours)
git config merge.ours.driver true 2>/dev/null || true

# ─── Helper: link Claude skill subdirectories into a skills parent directory ──
# Creates real directories (not symlinks) at the top level with a SKILL.md symlink
# inside, prefixed with "nstack-". This ensures Claude discovers them as top-level
# skills, not nested under nstack/.
link_claude_skill_dirs() {
  local nstack_dir="$1"
  local skills_dir="$2"
  local linked=()
  for skill_dir in "$nstack_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      dir_name="$(basename "$skill_dir")"
      # Skip node_modules
      [ "$dir_name" = "node_modules" ] && continue
      # Use frontmatter name: if present (e.g., run-tests/ with name: test → symlink as "test")
      skill_name=$(grep -m1 '^name:' "$skill_dir/SKILL.md" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]')
      [ -z "$skill_name" ] && skill_name="$dir_name"
      # Always prefix — don't double-prefix directories already named nstack-*
      case "$skill_name" in
        nstack-*) link_name="$skill_name" ;;
        *)        link_name="nstack-$skill_name" ;;
      esac
      target="$skills_dir/$link_name"
      # Upgrade old directory symlinks to real directories
      if [ -L "$target" ]; then
        rm -f "$target"
      fi
      # Create real directory with symlinked SKILL.md (absolute path)
      # Use mkdir -p unconditionally (idempotent) to avoid TOCTOU race
      mkdir -p "$target"
      # Validate target isn't a symlink before creating the link
      if [ -L "$target/SKILL.md" ]; then rm "$target/SKILL.md"; fi
      ln -snf "$nstack_dir/$dir_name/SKILL.md" "$target/SKILL.md"
      linked+=("$link_name")
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# ─── Helper: remove old unprefixed Claude skill entries ───────────────────────
# Migration: when switching from flat names to nstack- prefixed names,
# clean up stale symlinks or directories that point into the nstack directory.
cleanup_old_claude_symlinks() {
  local nstack_dir="$1"
  local skills_dir="$2"
  local removed=()
  for skill_dir in "$nstack_dir"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "node_modules" ] && continue
      # Skip already-prefixed dirs (nstack-upgrade) — no old symlink to clean
      case "$skill_name" in nstack-*) continue ;; esac
      old_target="$skills_dir/$skill_name"
      # Remove directory symlinks pointing into nstack/
      if [ -L "$old_target" ]; then
        link_dest="$(readlink "$old_target" 2>/dev/null || true)"
        case "$link_dest" in
          nstack/*|*/nstack/*)
            rm -f "$old_target"
            removed+=("$skill_name")
            ;;
        esac
      # Remove real directories with symlinked SKILL.md pointing into nstack/
      elif [ -d "$old_target" ] && [ -L "$old_target/SKILL.md" ]; then
        link_dest="$(readlink "$old_target/SKILL.md" 2>/dev/null || true)"
        case "$link_dest" in
          *nstack*)
            rm -rf "$old_target"
            removed+=("$skill_name")
            ;;
        esac
      fi
    fi
  done
  if [ ${#removed[@]} -gt 0 ]; then
    echo "  cleaned up old entries: ${removed[*]}"
  fi
}

# ─── Helper: link generated Codex skills into a skills parent directory ──
# Installs from .agents/skills/nstack-* (the generated Codex-format skills)
# instead of source dirs (which have Claude paths).
link_codex_skill_dirs() {
  local nstack_dir="$1"
  local skills_dir="$2"
  local agents_dir="$nstack_dir/.agents/skills"
  local linked=()

  if [ ! -d "$agents_dir" ]; then
    echo "  Generating .agents/ skill docs..."
    ( cd "$nstack_dir" && bun run gen:skill-docs --host codex )
  fi

  if [ ! -d "$agents_dir" ]; then
    echo "  warning: .agents/skills/ generation failed — run 'bun run gen:skill-docs --host codex' manually" >&2
    return 1
  fi

  for skill_dir in "$agents_dir"/nstack*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # Skip the sidecar directory — it contains runtime asset symlinks (bin/,
      # browse/), not a skill. Linking it would overwrite the root nstack
      # symlink that Step 5 already pointed at the repo root.
      [ "$skill_name" = "nstack" ] && continue
      target="$skills_dir/$skill_name"
      # Create or update symlink
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# ─── Helper: create .agents/skills/nstack/ sidecar symlinks ──────────
# Codex/Gemini/Cursor read skills from .agents/skills/. We link runtime
# assets (bin/, browse/dist/, review/, qa/, etc.) so skill templates can
# resolve paths like $SKILL_ROOT/review/design-checklist.md.
create_agents_sidecar() {
  local repo_root="$1"
  local agents_nstack="$repo_root/.agents/skills/nstack"
  mkdir -p "$agents_nstack"

  # Sidecar directories that skills reference at runtime
  for asset in bin browse review qa; do
    local src="$SOURCE_NSTACK_DIR/$asset"
    local dst="$agents_nstack/$asset"
    if [ -d "$src" ] || [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        ln -snf "$src" "$dst"
      fi
    fi
  done

  # Sidecar files that skills reference at runtime
  for file in ETHOS.md; do
    local src="$SOURCE_NSTACK_DIR/$file"
    local dst="$agents_nstack/$file"
    if [ -f "$src" ]; then
      if [ -L "$dst" ] || [ ! -e "$dst" ]; then
        ln -snf "$src" "$dst"
      fi
    fi
  done
}

# ─── Helper: create a minimal ~/.codex/skills/nstack runtime root ───────────
# Codex scans ~/.codex/skills recursively. Exposing the whole repo here causes
# duplicate skills because source SKILL.md files and generated Codex skills are
# both discoverable. Keep this directory limited to runtime assets + root skill.
create_codex_runtime_root() {
  local nstack_dir="$1"
  local codex_nstack="$2"
  local agents_dir="$nstack_dir/.agents/skills"

  if [ -L "$codex_nstack" ]; then
    rm -f "$codex_nstack"
  elif [ -d "$codex_nstack" ] && [ "$codex_nstack" != "$nstack_dir" ]; then
    # Old direct installs left a real directory here with stale source skills.
    # Remove it so we start fresh with only the minimal runtime assets.
    rm -rf "$codex_nstack"
  fi

  mkdir -p "$codex_nstack" "$codex_nstack/browse" "$codex_nstack/nstack-upgrade" "$codex_nstack/review"

  if [ -f "$agents_dir/nstack/SKILL.md" ]; then
    ln -snf "$agents_dir/nstack/SKILL.md" "$codex_nstack/SKILL.md"
  fi
  if [ -d "$nstack_dir/bin" ]; then
    ln -snf "$nstack_dir/bin" "$codex_nstack/bin"
  fi
  if [ -d "$nstack_dir/browse/dist" ]; then
    ln -snf "$nstack_dir/browse/dist" "$codex_nstack/browse/dist"
  fi
  if [ -d "$nstack_dir/browse/bin" ]; then
    ln -snf "$nstack_dir/browse/bin" "$codex_nstack/browse/bin"
  fi
  if [ -f "$agents_dir/nstack-upgrade/SKILL.md" ]; then
    ln -snf "$agents_dir/nstack-upgrade/SKILL.md" "$codex_nstack/nstack-upgrade/SKILL.md"
  fi
  # Review runtime assets (individual files, NOT the whole review/ dir which has SKILL.md)
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$nstack_dir/review/$f" ]; then
      ln -snf "$nstack_dir/review/$f" "$codex_nstack/review/$f"
    fi
  done
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$nstack_dir/ETHOS.md" ]; then
    ln -snf "$nstack_dir/ETHOS.md" "$codex_nstack/ETHOS.md"
  fi
}

create_factory_runtime_root() {
  local nstack_dir="$1"
  local factory_nstack="$2"
  local factory_dir="$nstack_dir/.factory/skills"

  if [ -L "$factory_nstack" ]; then
    rm -f "$factory_nstack"
  elif [ -d "$factory_nstack" ] && [ "$factory_nstack" != "$nstack_dir" ]; then
    rm -rf "$factory_nstack"
  fi

  mkdir -p "$factory_nstack" "$factory_nstack/browse" "$factory_nstack/nstack-upgrade" "$factory_nstack/review"

  if [ -f "$factory_dir/nstack/SKILL.md" ]; then
    ln -snf "$factory_dir/nstack/SKILL.md" "$factory_nstack/SKILL.md"
  fi
  if [ -d "$nstack_dir/bin" ]; then
    ln -snf "$nstack_dir/bin" "$factory_nstack/bin"
  fi
  if [ -d "$nstack_dir/browse/dist" ]; then
    ln -snf "$nstack_dir/browse/dist" "$factory_nstack/browse/dist"
  fi
  if [ -d "$nstack_dir/browse/bin" ]; then
    ln -snf "$nstack_dir/browse/bin" "$factory_nstack/browse/bin"
  fi
  if [ -f "$factory_dir/nstack-upgrade/SKILL.md" ]; then
    ln -snf "$factory_dir/nstack-upgrade/SKILL.md" "$factory_nstack/nstack-upgrade/SKILL.md"
  fi
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$nstack_dir/review/$f" ]; then
      ln -snf "$nstack_dir/review/$f" "$factory_nstack/review/$f"
    fi
  done
  if [ -f "$nstack_dir/ETHOS.md" ]; then
    ln -snf "$nstack_dir/ETHOS.md" "$factory_nstack/ETHOS.md"
  fi
}

link_factory_skill_dirs() {
  local nstack_dir="$1"
  local skills_dir="$2"
  local factory_dir="$nstack_dir/.factory/skills"
  local linked=()

  if [ ! -d "$factory_dir" ]; then
    echo "  Generating .factory/ skill docs..."
    ( cd "$nstack_dir" && bun run gen:skill-docs --host factory )
  fi

  if [ ! -d "$factory_dir" ]; then
    echo "  warning: .factory/skills/ generation failed — run 'bun run gen:skill-docs --host factory' manually" >&2
    return 1
  fi

  for skill_dir in "$factory_dir"/nstack*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      [ "$skill_name" = "nstack" ] && continue
      target="$skills_dir/$skill_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "$skill_dir" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

# 4. Install for Claude (default)
SKILLS_BASENAME="$(basename "$INSTALL_SKILLS_DIR")"
SKILLS_PARENT_BASENAME="$(basename "$(dirname "$INSTALL_SKILLS_DIR")")"
CODEX_REPO_LOCAL=0
if [ "$SKILLS_BASENAME" = "skills" ] && [ "$SKILLS_PARENT_BASENAME" = ".agents" ]; then
  CODEX_REPO_LOCAL=1
fi

if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  if [ "$SKILLS_BASENAME" = "skills" ]; then
    # Clean up stale unprefixed symlinks from previous installs
    cleanup_old_claude_symlinks "$SOURCE_NSTACK_DIR" "$INSTALL_SKILLS_DIR"
    # Patch name: fields BEFORE creating symlinks so link_claude_skill_dirs
    # reads the correct (patched) name: values for symlink naming
    "$SOURCE_NSTACK_DIR/bin/nstack-patch-names" "$SOURCE_NSTACK_DIR"
    link_claude_skill_dirs "$SOURCE_NSTACK_DIR" "$INSTALL_SKILLS_DIR"
    # Self-healing: re-run nstack-relink to ensure name: fields and directory
    # names are consistent. This catches cases where an interrupted
    # setup, stale git state, or gen:skill-docs left name: fields out of sync.
    NSTACK_RELINK="$SOURCE_NSTACK_DIR/bin/nstack-relink"
    if [ -x "$NSTACK_RELINK" ]; then
      NSTACK_SKILLS_DIR="$INSTALL_SKILLS_DIR" NSTACK_INSTALL_DIR="$SOURCE_NSTACK_DIR" "$NSTACK_RELINK" >/dev/null 2>&1 || true
    fi
    # Backwards-compat alias: /connect-chrome → /open-nstack-browser
    _OGB_LINK="$INSTALL_SKILLS_DIR/nstack-connect-chrome"
    if [ -L "$_OGB_LINK" ] || [ ! -e "$_OGB_LINK" ]; then
      ln -snf "nstack/open-nstack-browser" "$_OGB_LINK"
    fi
    if [ "$LOCAL_INSTALL" -eq 1 ]; then
      log "nstack ready (project-local)."
      log "  skills: $INSTALL_SKILLS_DIR"
    else
      log "nstack ready (claude)."
    fi
    log "  browse: $BROWSE_BIN"
  else
    # Not inside a skills/ directory — symlink into ~/.claude/skills/ and retry
    CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
    CLAUDE_NSTACK_LINK="$CLAUDE_SKILLS_DIR/nstack"
    mkdir -p "$CLAUDE_SKILLS_DIR"
    ln -snf "$SOURCE_NSTACK_DIR" "$CLAUDE_NSTACK_LINK"
    log "  symlinked $CLAUDE_NSTACK_LINK -> $SOURCE_NSTACK_DIR"
    INSTALL_SKILLS_DIR="$CLAUDE_SKILLS_DIR"
    INSTALL_NSTACK_DIR="$CLAUDE_NSTACK_LINK"
    # Clean up stale unprefixed symlinks from previous installs
    cleanup_old_claude_symlinks "$SOURCE_NSTACK_DIR" "$INSTALL_SKILLS_DIR"
    "$SOURCE_NSTACK_DIR/bin/nstack-patch-names" "$SOURCE_NSTACK_DIR"
    link_claude_skill_dirs "$SOURCE_NSTACK_DIR" "$INSTALL_SKILLS_DIR"
    NSTACK_RELINK="$SOURCE_NSTACK_DIR/bin/nstack-relink"
    if [ -x "$NSTACK_RELINK" ]; then
      NSTACK_SKILLS_DIR="$INSTALL_SKILLS_DIR" NSTACK_INSTALL_DIR="$SOURCE_NSTACK_DIR" "$NSTACK_RELINK" >/dev/null 2>&1 || true
    fi
    _OGB_LINK="$INSTALL_SKILLS_DIR/nstack-connect-chrome"
    if [ -L "$_OGB_LINK" ] || [ ! -e "$_OGB_LINK" ]; then
      ln -snf "nstack/open-nstack-browser" "$_OGB_LINK"
    fi
    log "nstack ready (claude)."
    log "  browse: $BROWSE_BIN"
  fi
fi

# 5. Install for Codex
if [ "$INSTALL_CODEX" -eq 1 ]; then
  if [ "$CODEX_REPO_LOCAL" -eq 1 ]; then
    CODEX_SKILLS="$INSTALL_SKILLS_DIR"
    CODEX_NSTACK="$INSTALL_NSTACK_DIR"
  fi
  mkdir -p "$CODEX_SKILLS"

  # Skip runtime root creation for repo-local installs — the checkout IS the runtime root.
  # create_codex_runtime_root would create self-referential symlinks (bin → bin, etc.).
  if [ "$CODEX_REPO_LOCAL" -eq 0 ]; then
    create_codex_runtime_root "$SOURCE_NSTACK_DIR" "$CODEX_NSTACK"
  fi
  # Install generated Codex-format skills (not Claude source dirs)
  link_codex_skill_dirs "$SOURCE_NSTACK_DIR" "$CODEX_SKILLS"

  log "nstack ready (codex)."
  log "  browse: $BROWSE_BIN"
  log "  codex skills: $CODEX_SKILLS"
fi

# 6. Install for Kiro CLI (copy from .agents/skills, rewrite paths)
if [ "$INSTALL_KIRO" -eq 1 ]; then
  KIRO_SKILLS="$HOME/.kiro/skills"
  AGENTS_DIR="$SOURCE_NSTACK_DIR/.agents/skills"
  mkdir -p "$KIRO_SKILLS"

  # Create nstack dir with symlinks for runtime assets, copy+sed for SKILL.md
  KIRO_NSTACK="$KIRO_SKILLS/nstack"
  # Remove old whole-dir symlink from previous installs
  [ -L "$KIRO_NSTACK" ] && rm -f "$KIRO_NSTACK"
  mkdir -p "$KIRO_NSTACK" "$KIRO_NSTACK/browse" "$KIRO_NSTACK/nstack-upgrade" "$KIRO_NSTACK/review"
  ln -snf "$SOURCE_NSTACK_DIR/bin" "$KIRO_NSTACK/bin"
  ln -snf "$SOURCE_NSTACK_DIR/browse/dist" "$KIRO_NSTACK/browse/dist"
  ln -snf "$SOURCE_NSTACK_DIR/browse/bin" "$KIRO_NSTACK/browse/bin"
  # ETHOS.md — referenced by "Search Before Building" in all skill preambles
  if [ -f "$SOURCE_NSTACK_DIR/ETHOS.md" ]; then
    ln -snf "$SOURCE_NSTACK_DIR/ETHOS.md" "$KIRO_NSTACK/ETHOS.md"
  fi
  # nstack-upgrade skill
  if [ -f "$AGENTS_DIR/nstack-upgrade/SKILL.md" ]; then
    ln -snf "$AGENTS_DIR/nstack-upgrade/SKILL.md" "$KIRO_NSTACK/nstack-upgrade/SKILL.md"
  fi
  # Review runtime assets (individual files, not whole dir)
  for f in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$SOURCE_NSTACK_DIR/review/$f" ]; then
      ln -snf "$SOURCE_NSTACK_DIR/review/$f" "$KIRO_NSTACK/review/$f"
    fi
  done

  # Rewrite root SKILL.md paths for Kiro
  sed -e "s|~/.claude/skills/nstack|~/.kiro/skills/nstack|g" \
      -e "s|\.claude/skills/nstack|.kiro/skills/nstack|g" \
      -e "s|\.claude/skills|.kiro/skills|g" \
      "$SOURCE_NSTACK_DIR/SKILL.md" > "$KIRO_NSTACK/SKILL.md"

  if [ ! -d "$AGENTS_DIR" ]; then
    echo "  warning: no .agents/skills/ directory found — run 'bun run build' first" >&2
  else
    for skill_dir in "$AGENTS_DIR"/nstack*/; do
      [ -f "$skill_dir/SKILL.md" ] || continue
      skill_name="$(basename "$skill_dir")"
      target_dir="$KIRO_SKILLS/$skill_name"
      mkdir -p "$target_dir"
      # Generated Codex skills use $HOME/.codex (not ~/), plus $NSTACK_ROOT variables.
      # Rewrite the default NSTACK_ROOT value and any remaining literal paths.
      sed -e 's|\$HOME/.codex/skills/nstack|$HOME/.kiro/skills/nstack|g' \
          -e "s|~/.codex/skills/nstack|~/.kiro/skills/nstack|g" \
          -e "s|~/.claude/skills/nstack|~/.kiro/skills/nstack|g" \
          "$skill_dir/SKILL.md" > "$target_dir/SKILL.md"
    done
    echo "nstack ready (kiro)."
    echo "  browse: $BROWSE_BIN"
    echo "  kiro skills: $KIRO_SKILLS"
  fi
fi

# 6b. Install for Factory Droid
if [ "$INSTALL_FACTORY" -eq 1 ]; then
  mkdir -p "$FACTORY_SKILLS"
  create_factory_runtime_root "$SOURCE_NSTACK_DIR" "$FACTORY_NSTACK"
  link_factory_skill_dirs "$SOURCE_NSTACK_DIR" "$FACTORY_SKILLS"
  echo "nstack ready (factory)."
  echo "  browse: $BROWSE_BIN"
  echo "  factory skills: $FACTORY_SKILLS"
fi

# 7. Create .agents/ sidecar symlinks for the real Codex skill target.
# The root Codex skill ends up pointing at $SOURCE_NSTACK_DIR/.agents/skills/nstack,
# so the runtime assets must live there for both global and repo-local installs.
if [ "$INSTALL_CODEX" -eq 1 ]; then
  create_agents_sidecar "$SOURCE_NSTACK_DIR"
fi

# 8. Run pending version migrations
# Migrations handle state fixes that ./setup alone can't cover (stale config,
# orphaned files, directory structure changes). Each migration is idempotent.
MIGRATIONS_DIR="$SOURCE_NSTACK_DIR/nstack-upgrade/migrations"
CURRENT_VERSION=$(cat "$SOURCE_NSTACK_DIR/VERSION" 2>/dev/null || echo "unknown")
LAST_SETUP_VERSION=$(cat "$HOME/.nstack/.last-setup-version" 2>/dev/null || echo "0.0.0.0")
if [ -d "$MIGRATIONS_DIR" ] && [ "$CURRENT_VERSION" != "unknown" ] && [ "$LAST_SETUP_VERSION" != "$CURRENT_VERSION" ]; then
  # Fresh install (no marker file) — skip migrations, just write marker
  if [ ! -f "$HOME/.nstack/.last-setup-version" ]; then
    : # fall through to marker write below
  else
    find "$MIGRATIONS_DIR" -maxdepth 1 -name 'v*.sh' -type f 2>/dev/null | sort -V | while IFS= read -r migration; do
      m_ver="$(basename "$migration" .sh | sed 's/^v//')"
      # Run if migration is newer than last setup version AND not newer than current version
      if [ "$(printf '%s\n%s' "$LAST_SETUP_VERSION" "$m_ver" | sort -V | head -1)" = "$LAST_SETUP_VERSION" ] && [ "$LAST_SETUP_VERSION" != "$m_ver" ] \
         && [ "$(printf '%s\n%s' "$m_ver" "$CURRENT_VERSION" | sort -V | tail -1)" = "$CURRENT_VERSION" ]; then
        echo "  running migration $m_ver..."
        bash "$migration" || echo "  warning: migration $m_ver had errors (non-fatal)"
      fi
    done
  fi
fi
mkdir -p "$HOME/.nstack"
if [ "$CURRENT_VERSION" != "unknown" ]; then
  echo "$CURRENT_VERSION" > "$HOME/.nstack/.last-setup-version"
fi

# 9. First-time welcome + legacy cleanup
if [ ! -f "$HOME/.nstack/.welcome-seen" ]; then
  log "  Welcome! Run /nstack-upgrade anytime to stay current."
  touch "$HOME/.nstack/.welcome-seen"
fi
# Cross-project sharing: tell user the default + how to change it.
# v0.18+: cross_project_learnings is OFF by default (privacy-first). Per-repo
# prompts fire on first use. This setup-time message avoids "where did the
# prompt go?" confusion.
if [ ! -f "$HOME/.nstack/.cross-project-default-shown" ]; then
  log ""
  log "  Cross-project learning sharing is OFF by default."
  log "  nstack will ask per-repo on first use, or run:"
  log "    nstack-config set --local cross_project_learnings true"
  log "  See docs/migrations/v0.18.0.0.md for details."
  touch "$HOME/.nstack/.cross-project-default-shown"
fi
rm -f /tmp/nstack-latest-version

# 10. Team mode: register/unregister SessionStart hook
SETTINGS_HOOK="$SOURCE_NSTACK_DIR/bin/nstack-settings-hook"
HOOK_CMD="$SOURCE_NSTACK_DIR/bin/nstack-session-update"

if [ "$TEAM_MODE" -eq 1 ]; then
  "$NSTACK_CONFIG" set auto_upgrade true 2>/dev/null || true
  "$NSTACK_CONFIG" set team_mode true 2>/dev/null || true

  # Register SessionStart hook in Claude Code settings
  if [ -x "$SETTINGS_HOOK" ]; then
    "$SETTINGS_HOOK" add "$HOOK_CMD" 2>/dev/null || true
  fi

  log ""
  log "Team mode enabled: nstack will auto-update at the start of each Claude Code session."
  log "  Hook: $HOOK_CMD"
  log "  To disable: ./setup --no-team"
  log ""
  log "Bootstrap your repo:"
  log "  cd <your-repo> && $SOURCE_NSTACK_DIR/bin/nstack-team-init required"
fi

if [ "$NO_TEAM_MODE" -eq 1 ]; then
  "$NSTACK_CONFIG" set auto_upgrade false 2>/dev/null || true
  "$NSTACK_CONFIG" set team_mode false 2>/dev/null || true

  # Remove SessionStart hook from Claude Code settings
  if [ -x "$SETTINGS_HOOK" ]; then
    "$SETTINGS_HOOK" remove "$HOOK_CMD" 2>/dev/null || true
  fi

  log "Team mode disabled: auto-update hook removed."
fi
