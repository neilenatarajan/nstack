#!/usr/bin/env bash
# nstack-review-log — atomically log a review result
# Usage: nstack-review-log '{"skill":"...","timestamp":"...","status":"..."}'
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/nstack-project-dir"
if [ -z "$_NSTACK_PROJ" ]; then
  echo "nstack-review-log: not in a git repository" >&2
  exit 1
fi
eval "$("$SCRIPT_DIR/nstack-slug" 2>/dev/null)"
mkdir -p "$_NSTACK_PROJ"

# Validate: input must be parseable JSON (reject malformed or injection attempts)
INPUT="$1"
if ! printf '%s' "$INPUT" | bun -e "JSON.parse(await Bun.stdin.text())" 2>/dev/null; then
  # Not valid JSON — refuse to append
  echo "nstack-review-log: invalid JSON, skipping" >&2
  exit 1
fi

echo "$INPUT" >> "$_NSTACK_PROJ/$BRANCH-reviews.jsonl"
