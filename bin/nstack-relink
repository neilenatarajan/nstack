#!/usr/bin/env bash
# nstack-relink — re-create skill symlinks with nstack-* prefix
#
# Usage:
#   nstack-relink
#
# Env overrides (for testing):
#   NSTACK_STATE_DIR   — override ~/.nstack state directory
#   NSTACK_INSTALL_DIR — override nstack install directory
#   NSTACK_SKILLS_DIR  — override target skills directory
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Detect install dir
INSTALL_DIR="${NSTACK_INSTALL_DIR:-}"
if [ -z "$INSTALL_DIR" ]; then
  if [ -d "$HOME/.claude/skills/nstack" ]; then
    INSTALL_DIR="$HOME/.claude/skills/nstack"
  elif [ -d "${SCRIPT_DIR}/.." ] && [ -f "${SCRIPT_DIR}/../setup" ]; then
    INSTALL_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
  fi
fi

if [ -z "$INSTALL_DIR" ] || [ ! -d "$INSTALL_DIR" ]; then
  echo "Error: nstack install directory not found." >&2
  echo "Run: cd ~/.claude/skills/nstack && ./setup" >&2
  exit 1
fi

# Detect target skills dir
SKILLS_DIR="${NSTACK_SKILLS_DIR:-$(dirname "$INSTALL_DIR")}"
[ -d "$SKILLS_DIR" ] || mkdir -p "$SKILLS_DIR"

# Helper: remove old skill entry (symlink or real directory with symlinked SKILL.md)
_cleanup_skill_entry() {
  local entry="$1"
  if [ -L "$entry" ]; then
    rm -f "$entry"
  elif [ -d "$entry" ] && [ -L "$entry/SKILL.md" ]; then
    rm -rf "$entry"
  fi
}

# Discover skills (directories with SKILL.md, excluding meta dirs)
SKILL_COUNT=0
for skill_dir in "$INSTALL_DIR"/*/; do
  [ -d "$skill_dir" ] || continue
  skill=$(basename "$skill_dir")
  # Skip non-skill directories
  case "$skill" in bin|browse|design|docs|extension|lib|node_modules|scripts|test|.git|.github) continue ;; esac
  [ -f "$skill_dir/SKILL.md" ] || continue

  # Always prefix — don't double-prefix directories already named nstack-*
  case "$skill" in
    nstack-*) link_name="$skill" ;;
    *)        link_name="nstack-$skill" ;;
  esac
  # Remove old flat entry if it exists (and isn't the same as the new link)
  [ "$link_name" != "$skill" ] && _cleanup_skill_entry "$SKILLS_DIR/$skill"
  target="$SKILLS_DIR/$link_name"
  # Upgrade old directory symlinks to real directories
  [ -L "$target" ] && rm -f "$target"
  # Create real directory with symlinked SKILL.md (absolute path)
  mkdir -p "$target"
  ln -snf "$INSTALL_DIR/$skill/SKILL.md" "$target/SKILL.md"
  SKILL_COUNT=$((SKILL_COUNT + 1))
done

# Patch SKILL.md name: fields to use nstack- prefix
"$INSTALL_DIR/bin/nstack-patch-names" "$INSTALL_DIR"

echo "Relinked $SKILL_COUNT skills as nstack-*"
