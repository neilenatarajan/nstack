#!/usr/bin/env bash
# nstack-config — read/write layered config (local > global)
#
# Usage:
#   nstack-config get <key>                — read (local .nstack/config.yaml > global ~/.nstack/config.yaml)
#   nstack-config set <key> <value>        — write to local if in git repo, global otherwise
#   nstack-config set --local <key> <value>  — write to .nstack/config.yaml in repo root
#   nstack-config set --global <key> <value> — write to ~/.nstack/config.yaml
#   nstack-config list                     — show all config (merged view)
#
# Env overrides (for testing):
#   NSTACK_STATE_DIR  — override ~/.nstack state directory
set -euo pipefail

GLOBAL_DIR="${NSTACK_STATE_DIR:-$HOME/.nstack}"
GLOBAL_FILE="$GLOBAL_DIR/config.yaml"

# Resolve local config: .nstack/config.yaml in git repo root
_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)
LOCAL_FILE=""
[ -n "$_ROOT" ] && LOCAL_FILE="$_ROOT/.nstack/config.yaml"

# Annotated header for new config files. Written once on first `set`.
CONFIG_HEADER='# nstack configuration — edit freely, changes take effect on next skill run.
# Docs: https://github.com/neilenatarajan/nstack
#
# ─── Behavior ────────────────────────────────────────────────────────
# proactive: true           # Auto-invoke skills when your request matches one.
#                           # Set to false to only run skills you type explicitly.
#
# routing_declined: false   # Set to true to skip the CLAUDE.md routing injection
#                           # prompt. Set back to false to be asked again.
#
# ─── Updates ─────────────────────────────────────────────────────────
# auto_upgrade: false       # true = silently upgrade on session start
# update_check: true        # false = suppress version check notifications
#
# ─── Advanced ────────────────────────────────────────────────────────
# codex_reviews: enabled    # disabled = skip Codex adversarial reviews in /ship
# nstack_contributor: false # true = file field reports when nstack misbehaves
# skip_eng_review: false    # true = skip eng review gate in /ship (not recommended)
#
'

# Read a value from a config file (empty string if not found)
_read_key() {
  local file="$1" key="$2"
  grep -E "^${key}:" "$file" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
}

# Write a key-value pair to a config file
_write_key() {
  local file="$1" key="$2" value="$3" dir
  dir="$(dirname "$file")"
  mkdir -p "$dir"
  # Write annotated header on first creation
  if [ ! -f "$file" ]; then
    printf '%s' "$CONFIG_HEADER" > "$file"
  fi
  # Auto-add .nstack/ to .gitignore if writing local config
  if [ -n "$_ROOT" ] && [ "$dir" = "$_ROOT/.nstack" ]; then
    if [ -f "$_ROOT/.gitignore" ]; then
      grep -qxF '.nstack/' "$_ROOT/.gitignore" 2>/dev/null || echo '.nstack/' >> "$_ROOT/.gitignore"
    fi
  fi
  # Escape sed special chars in value and drop embedded newlines
  local esc_value
  esc_value="$(printf '%s' "$value" | head -1 | sed 's/[&/\]/\\&/g')"
  if grep -qE "^${key}:" "$file" 2>/dev/null; then
    local tmpfile
    tmpfile="$(mktemp "${file}.XXXXXX")"
    sed "/^${key}:/s/.*/${key}: ${esc_value}/" "$file" > "$tmpfile" && mv "$tmpfile" "$file"
  else
    echo "${key}: ${value}" >> "$file"
  fi
}

case "${1:-}" in
  get)
    KEY="${2:?Usage: nstack-config get <key>}"
    # Validate key (alphanumeric + underscore only)
    if ! printf '%s' "$KEY" | grep -qE '^[a-zA-Z0-9_]+$'; then
      echo "Error: key must contain only alphanumeric characters and underscores" >&2
      exit 1
    fi
    # Local > global resolution
    VAL=""
    [ -n "$LOCAL_FILE" ] && VAL=$(_read_key "$LOCAL_FILE" "$KEY")
    [ -z "$VAL" ] && VAL=$(_read_key "$GLOBAL_FILE" "$KEY")
    echo "$VAL"
    ;;
  set)
    # Parse flags: --local, --global
    SCOPE=""
    shift
    while [ $# -gt 0 ]; do
      case "$1" in
        --local)  SCOPE="local"; shift ;;
        --global) SCOPE="global"; shift ;;
        -*) echo "Unknown flag: $1" >&2; exit 1 ;;
        *)  break ;;
      esac
    done
    KEY="${1:?Usage: nstack-config set [--local|--global] <key> <value>}"
    VALUE="${2:?Usage: nstack-config set [--local|--global] <key> <value>}"
    # Validate key
    if ! printf '%s' "$KEY" | grep -qE '^[a-zA-Z0-9_]+$'; then
      echo "Error: key must contain only alphanumeric characters and underscores" >&2
      exit 1
    fi
    # Determine target file
    TARGET=""
    if [ "$SCOPE" = "global" ]; then
      TARGET="$GLOBAL_FILE"
    elif [ "$SCOPE" = "local" ]; then
      if [ -z "$LOCAL_FILE" ]; then
        echo "Warning: not in a git repo, writing to global config instead." >&2
        TARGET="$GLOBAL_FILE"
      else
        TARGET="$LOCAL_FILE"
      fi
    else
      # Default: local if in git repo, global otherwise
      if [ -n "$LOCAL_FILE" ]; then
        TARGET="$LOCAL_FILE"
      else
        TARGET="$GLOBAL_FILE"
      fi
    fi
    _write_key "$TARGET" "$KEY" "$VALUE"
    ;;
  list)
    # Show merged view: global first, then local overrides
    if [ -f "$GLOBAL_FILE" ]; then
      echo "# global: $GLOBAL_FILE"
      cat "$GLOBAL_FILE"
    fi
    if [ -n "$LOCAL_FILE" ] && [ -f "$LOCAL_FILE" ]; then
      echo ""
      echo "# local: $LOCAL_FILE"
      cat "$LOCAL_FILE"
    fi
    ;;
  *)
    echo "Usage: nstack-config {get|set|list} [--local|--global] [key] [value]"
    exit 1
    ;;
esac
