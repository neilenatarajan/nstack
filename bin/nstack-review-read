#!/usr/bin/env bash
# nstack-review-read — read review log and config for dashboard
# Usage: nstack-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/nstack-project-dir"
eval "$("$SCRIPT_DIR/nstack-slug" 2>/dev/null)"
if [ -n "$_NSTACK_PROJ" ]; then
  cat "$_NSTACK_PROJ/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
else
  echo "NO_REVIEWS"
fi
echo "---CONFIG---"
"$SCRIPT_DIR/nstack-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
